MONGODB_URI=:test123@clusterlifeos.nsnqvgr.mongodb.net/?appName=ClusterLifeOS
PORT=5000

# Route Optimization & Congestion APIs
# OSRM works free with no key. Optional keys below add live traffic or truck routing.

# OpenRouteService (free key — truck/HGV routing): https://openrouteservice.org/
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key

# Live traffic routing (optional — pick one or both)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Optional port congestion
MARINETRAFFIC_API_KEY=your_marinetraffic_api_key

# Optional air cargo congestion
AVIATIONSTACK_API_KEY=your_aviationstack_api_key

# Theft Reports — manager auth & notifications
JWT_SECRET=your_jwt_secret_change_in_production
MANAGER_PASSWORD=your_manager_password
MANAGER_API_TOKEN=optional_api_token_for_server_to_server
BACKEND_PUBLIC_URL=http://localhost:5000
APP_BASE_URL=http://localhost:3000

# Notifications (production — at least one recommended)
RESEND_API_KEY=your_resend_api_key
NOTIFICATION_FROM=alerts@yourdomain.com
NOTIFICATION_EMAIL=operations@yourdomain.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx
DISPATCH_NOTIFICATION_EMAIL=dispatch@yourdomain.com

# Warehouse Congestion Predictor — Google Gemini AI
GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
